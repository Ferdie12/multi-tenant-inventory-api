generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String                @id @default(uuid()) @db.Uuid
  apiKeyHash  String                @unique
  name        String
  products    Product[]
  variants    ProductVariant[]
  warehouses  Warehouse[]
  stockLevels StockLevel[]
  adjustments InventoryAdjustment[]
  transfers   StockTransfer[]
  createdAt   DateTime              @default(now())
}

model Product {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  sku           String
  variantSchema Json
  variants      ProductVariant[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([tenantId, sku])
  @@unique([id, tenantId])
  @@index([tenantId])
}

model ProductVariant {
  id          String                @id @default(uuid()) @db.Uuid
  tenantId    String                @db.Uuid
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String                @db.Uuid
  product     Product               @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: Cascade)
  sku         String
  attributes  Json
  stockLevels StockLevel[]
  adjustments InventoryAdjustment[]
  transfers   StockTransfer[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([tenantId, sku])
  @@unique([id, tenantId])
  @@index([tenantId, productId])
}

model Warehouse {
  id          String                @id @default(uuid()) @db.Uuid
  tenantId    String                @db.Uuid
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  stockLevels StockLevel[]
  adjustments InventoryAdjustment[]
  sourceTransfers StockTransfer[] @relation("SourceTransfers")
  targetTransfers StockTransfer[] @relation("TargetTransfers")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([tenantId, code])
  @@unique([id, tenantId])
  @@index([tenantId])
}

model StockLevel {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @db.Uuid
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variantId   String         @db.Uuid
  variant     ProductVariant @relation(fields: [variantId, tenantId], references: [id, tenantId], onDelete: Cascade)
  warehouseId String         @db.Uuid
  warehouse   Warehouse      @relation(fields: [warehouseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  /// The initial PostgreSQL migration also enforces quantity >= 0 with a CHECK constraint.
  quantity    Int            @default(0)
  updatedAt   DateTime       @updatedAt

  @@unique([tenantId, variantId, warehouseId])
  @@index([tenantId, warehouseId])
}

model InventoryAdjustment {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @db.Uuid
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variantId    String         @db.Uuid
  variant      ProductVariant @relation(fields: [variantId, tenantId], references: [id, tenantId], onDelete: Cascade)
  warehouseId  String         @db.Uuid
  warehouse    Warehouse      @relation(fields: [warehouseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  delta        Int
  balanceAfter Int
  reason       String?
  createdAt    DateTime       @default(now())

  @@index([tenantId, variantId, warehouseId, createdAt])
}

model StockTransfer {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @db.Uuid
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variantId         String         @db.Uuid
  variant           ProductVariant @relation(fields: [variantId, tenantId], references: [id, tenantId], onDelete: Cascade)
  sourceWarehouseId String         @db.Uuid
  sourceWarehouse   Warehouse      @relation("SourceTransfers", fields: [sourceWarehouseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  targetWarehouseId String         @db.Uuid
  targetWarehouse   Warehouse      @relation("TargetTransfers", fields: [targetWarehouseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  quantity          Int
  reason            String?
  createdAt         DateTime       @default(now())

  @@index([tenantId, variantId, createdAt])
}
